PORT=3000
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=pos_db
# Producción: usar host/credenciales de tu proveedor (Hostinger, etc.)
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=8h
# Opcional. Vercel no permite TZ; por defecto ya es America/Bogota en el código.
# APP_TIMEZONE=America/Bogota

# Usuarios demo: se crean en BD al arrancar (seed/demo.data.ts)
# super@pos.local / super123, admin@pos.local / admin123, etc.

# Tiendas que NUNCA reciben productos demo al desplegar (códigos separados por coma)
# Flor de Luna ya está protegida por defecto en el código
# SEED_SKIP_STORES=Flor-de-luna,mi-otra-tienda

# En Vercel el seed automático NO corre (process.env.VERCEL). Tus productos no se borran al desplegar.

# Supabase Storage (S3) — imágenes de productos
# Dashboard: Storage > S3 Connection (endpoint y región)
SUPABASE_S3_ENDPOINT=https://mehjmvdtiandtalbawqh.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=us-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_BUCKET=imagenes

# Configura estos valores según tu instalación local de MySQL.
# Crea la base de datos antes de iniciar: CREATE DATABASE pos_db;
